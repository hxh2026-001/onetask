{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "outDir": "server",
    "types": ["node", "better-sqlite3"]
  },
  "include": ["server/geneticAlgorithm.ts", "server/database.ts"]
}