{
  "name": "syntax-candy",
  "version": "1.0.0",
  "description": "Compiler Frontend Visualization Tool",
  "main": "server.js",
  "scripts": {
    "build": "rollup -c --bundleConfigAsCjs",
    "dev": "rollup -c -w",
    "start": "node server.js",
    "start:dev": "concurrently \"rollup -c -w\" \"nodemon server.js\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "svelte": "^4.2.12"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "rollup": "^4.9.6",
    "rollup-plugin-svelte": "^7.1.6"
  }
}