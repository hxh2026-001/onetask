<div id="origami-canvas-container">
  <div id="app"></div>
</div>

<script>
  console.log('OrigamiCanvas: Loading...');
  
  async function loadOrigami() {
    try {
      console.log('OrigamiCanvas: Importing OrigamiEngine...');
      const { OrigamiEngine } = await import('../engine/OrigamiEngine');
      console.log('OrigamiCanvas: OrigamiEngine imported successfully');
      
      const engine = new OrigamiEngine();
      console.log('OrigamiCanvas: OrigamiEngine instance created');
      
      engine.init();
      console.log('OrigamiCanvas: OrigamiEngine initialized');
      
      window.addEventListener('resize', () => {
        engine.handleResize();
      });
      
      console.log('OrigamiCanvas: All set up!');
    } catch (error) {
      console.error('OrigamiCanvas: Error loading origami:', error);
    }
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadOrigami);
  } else {
    loadOrigami();
  }
</script>

<style>
  #origami-canvas-container {
    width: 100vw;
    height: 100vh;
    position: fixed;
    top: 0;
    left: 0;
    background: #0a0a1a;
  }
  #app {
    width: 100%;
    height: 100%;
    margin-left: 320px;
  }
</style>