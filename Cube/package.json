{
  "name": "cube-encoding-system",
  "version": "1.0.0",
  "description": "魔方状态编码与复原系统 - Vite + SolidJS + Express + Three.js + better-sqlite3",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite --port 3001",
    "dev:server": "nodemon --exec tsx server/index.ts",
    "build": "vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^9.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "solid-js": "^1.8.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/three": "^0.160.0",
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-solid": "^2.8.0"
  }
}
